# GitLab instance URL (no trailing slash)
GITLAB_URL=https://your.gitlab.url.com

# Personal Access Token with api + read_repository scopes
GITLAB_TOKEN=your-pat-here

# Set to "false" if your GitLab instance uses a self-signed certificate
GITLAB_SSL_VERIFY=true

# MCP server bind settings
MCP_HOST=0.0.0.0
MCP_PORT=8000
